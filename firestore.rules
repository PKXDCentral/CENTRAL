rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
             (request.auth.token.email == "kawanyuri35@gmail.com" || request.auth.token.email == "eukoosh@gmail.com");
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // News rules
    match /news/{newsId} {
      allow read: if true;
      allow create: if isAdmin() && 
                       isValidId(newsId) && 
                       incoming().id == newsId &&
                       incoming().title is string && incoming().title.size() <= 200 &&
                       incoming().excerpt is string && incoming().excerpt.size() <= 500 &&
                       incoming().content is string && incoming().content.size() <= 10000 &&
                       incoming().category in ['spoilers', 'updates', 'codes', 'events'] &&
                       incoming().imageUrl is string &&
                       incoming().date is string &&
                       incoming().author is string;
      
      allow update: if isAdmin() && 
                       incoming().title is string && incoming().title.size() <= 200 &&
                       incoming().excerpt is string && incoming().excerpt.size() <= 500 &&
                       incoming().content is string && incoming().content.size() <= 10000 &&
                       incoming().category in ['spoilers', 'updates', 'codes', 'events'] &&
                       incoming().imageUrl is string &&
                       incoming().date is string &&
                       incoming().author is string;
                       
      allow delete: if isAdmin();
    }

    // AppSettings rules
    match /settings/{settingsId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // PastSpoiler rules
    match /past_spoilers/{spoilerId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Featured Videos rules
    match /featured_videos/{videoId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Theories rules
    match /theories/{theoryId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (incoming().diff(existing()).affectedKeys().hasOnly(['likes']) && incoming().likes == existing().likes + 1);
    }

    // Shorts rules
    match /shorts/{shortId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Notifications rules
    match /notifications/{notifId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Leaderboard rules
    match /leaderboard/{playerId} {
      allow read: if true;
      allow create, update: if isSignedIn() &&
                               request.auth.uid == playerId &&
                               incoming().id == playerId &&
                               incoming().name is string && incoming().name.size() <= 40 &&
                               incoming().level is number && incoming().level >= 1 && incoming().level <= 10000 &&
                               incoming().xp is number && incoming().xp >= 0 && incoming().xp < 100 &&
                               incoming().flames is number && incoming().flames >= 0 && incoming().flames <= 100000 &&
                               incoming().updatedAt is number;
      allow delete: if isAdmin();
    }
  }
}
